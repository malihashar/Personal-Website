# Copy this file to `.env.local` and fill in values locally.
# `.env.local` is gitignored — do not commit it.
#
# Server-only secrets belong in variables WITHOUT the NEXT_PUBLIC_ prefix
# and must only be read from Route Handlers / Server Components / server code.
#
# Example (uncomment when you need them):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
